{
  "name": "root",
  "private": true,
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-import-resolver-typescript": "^3.0.0",
    "eslint-plugin-import": "^2.25.3",
    "eslint-plugin-prettier": "^5.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "scripts": {
    "bootstrap": "yarn install",
    "run:core": "yarn workspace @heli-os/vallista-core run:core",
    "build:core": "yarn workspace @heli-os/vallista-core build:core",
    "publish:core": "yarn workspace @heli-os/vallista-core publish:core",
    "run:playground": "yarn workspace @vallista-land/playground run:playground",
    "build:playground": "yarn workspace @vallista-land/playground build:playground",
    "clean:playground": "cd packages/playground && gatsby clean",
    "run:blog": "yarn workspace @vallista-land/blog run:blog",
    "build:blog": "yarn workspace @vallista-land/blog build:blog",
    "clean:blog": "cd packages/blog && gatsby clean",
    "post:blog": "cd packages/blog && yarn post:blog",
    "deploy:blog": "cd packages/blog && yarn deploy:blog",
    "directory:blog": "cd packages/blog",
    "deploy:blog-ex": "yarn deploy:blog"
  },
  "workspaces": {
    "packages": [
      "packages/*"
    ]
  },
  "lint-staged": {
    "*.{js,ts,tsx,jsx}": [
      "eslint --quiet --fix"
    ],
    "*.{json,md,html,js,jsx,ts,tsx}": [
      "prettier --write"
    ]
  },
  "dependencies": {}
}
